# Site Configuration
NEXT_PUBLIC_SITE_URL=https://techrupt.me
NEXT_PUBLIC_SITE_NAME="Techrupt"
NEXT_PUBLIC_SITE_DESCRIPTION="Tech, AI & Cybersecurity News"

# Analytics — Plausible (privacy-first, no cookie consent banner needed)
# Sign up at plausible.io and add your domain
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=techrupt.me

# Analytics — Google Analytics 4 (optional, required for AdSense)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Newsletter — beehiiv
# Sign up at beehiiv.com → Settings → API → Generate key
# Publication ID is in your beehiiv dashboard URL: app.beehiiv.com/publications/YOUR_PUB_ID
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUB_ID=your_beehiiv_publication_id_here

# Content API (for future headless CMS — Payload, Contentful, Sanity)
# CMS_API_URL=
# CMS_API_KEY=
